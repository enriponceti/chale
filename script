COMMENT ON TABLE apps.hospede IS 'Caso você queira registrar todos os ocupantes, não só o responsável.

Objetivo: útil para controle de hospedagem e segurança.';
COMMENT ON COLUMN apps.hospede.tipo_hospede IS 'titular, acompanhante, criança';


CREATE TABLE apps.pagamento (
                id INTEGER NOT NULL,
                id_reserva INTEGER NOT NULL,
                data_pagamento TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
                valor_pago NUMERIC NOT NULL,
                forma_pagamento VARCHAR NOT NULL,
                status_pagamento VARCHAR NOT NULL,
                tipo_pagamento VARCHAR,
                codigo_transacao VARCHAR,
                observacao VARCHAR NOT NULL,
