COMMENT ON TABLE apps.pagamento IS 'Permite múltiplos pagamentos por reserva.';
COMMENT ON COLUMN apps.pagamento.forma_pagamento IS 'pix, cartão, dinheiro, boleto, transferência';
COMMENT ON COLUMN apps.pagamento.status_pagamento IS 'pendente, pago, estornado, parcial';
COMMENT ON COLUMN apps.pagamento.tipo_pagamento IS 'sinal, restante, caução, taxa extra';


CREATE TABLE apps.chale_comodidade (
